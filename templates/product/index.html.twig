{% extends 'base.html.twig' %}

{% block body %}
  <h3 class="mb-3">ProductBundle</h3>

  <div class="dropdown">
    <button class="btn btn-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
      {{ 'generic.add'|trans }}
    </button>
    <ul class="dropdown-menu">
      <li><a class="dropdown-item" href="{{ path('app_product_new') }}">简单的商品</a></li>
      <li><a class="dropdown-item" href="{{ path('app_product_new', {combinable: true}) }}">多选项商品</a></li>
    </ul>
  </div>

  <div {{ stimulus_controller('product-variants') }}>
    {% embed 'table.html.twig' %}
      {% block th %}
        <th class="text-nowrap">{{ 'product.name'|trans }}</th>
        <th class="text-nowrap">{{ 'product_variant.price'|trans }}</th>
        <th class="text-nowrap">{{ 'generic.created_at'|trans }}</th>
        <th class="text-nowrap">{{ 'generic.action'|trans }}</th>
      {% endblock %}

      {% block td %}
        <td class="text-nowrap">
          <div class="d-flex align-items-center">
            <img src="{{ _item.img }}" width="50px" class="img-thumbnail" />
            <div class="mx-3">
              <p class="m-0 text-break">{{ _item.name }}</p>
              {% if _item.options|length %}
                <small class="fs-sm text-secondary">
                  {% for option in _item.options %}
                    <a href="{{ path('app_productoption_edit', {_id: option.id}) }}" class="text-reset text-decoration-none">{{ option.name }} ({{ option.values|length }})</a>
                  {% endfor %}
                </small>
              {% endif %}
            </div>
          </div>
        </td>
        <td class="text-nowrap">
          {%- set _variants = _item.variants|filter(v => v.enabled) -%}
          {%- set _prices = _variants|map(v => v.price) %}
          {{ _prices ? min(_prices)|intl_currency : '-' }}
        </td>
        <td class="text-nowrap">{{ _item.createdAt|intl_date }}</td>
        <td class="text-nowrap">
          <a role="button" class="btn-link" {{ stimulus_action('product-variants', 'show', null, {url: path('app_product_variants', {id: _item.id}), name: _item.name}) }}>
            {{ 'product.variants'|trans }}
            <small>({{ _variants|length }}/{{ _item.variants|length ?: 1 }})</small>
          </a>
          <a href="{{ path('app_product_edit', {_id: _item.id}) }}">{{ 'generic.edit'|trans }}</a>
          <a href="{{ path('app_product_delete', {_id: _item.id, _token: csrf_token('delete' ~ _item.id)}) }}" onclick="return confirm('{{ 'generic.delete_confirmation'|trans }}')">{{ 'generic.delete'|trans }}</a>
        </td>
      {% endblock %}
    {% endembed %}

    <div class="modal fade" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" {{ stimulus_target('product-variants', 'modal') }} {{ stimulus_action('product-variants', 'onShow', 'show.bs.modal')|stimulus_action('product-variants', 'onHide', 'hide.bs.modal') }}>
      <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
          <div class="modal-header">
            <h6 class="modal-title">{{ 'product.variants'|trans }}</h6>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body"></div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'generic.cancel'|trans }}</button>
            <button type="button" class="btn btn-primary" {{ stimulus_action('product-variants', 'submit') }}>{{ 'generic.save'|trans }}</button>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
