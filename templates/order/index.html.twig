{% extends 'base.html.twig' %}

{% block stylesheets %}
  <style>
    [data-bs-toggle] .bi:before {
      transition: transform .15s ease;
    }
    [data-bs-toggle][aria-expanded=true] .bi:before {
      transform: rotate(180deg);
    }
  </style>
{% endblock %}

{% macro nav_link(item, count, active) %}
  {%- set _item -%}
    {{- item|trans -}}<small class="text-body-secondary ms-1">({{ count ?? 0 }})</small>
  {%- endset -%}

  {%- if active -%}
    <span class="nav-link active" aria-current="page">{{ _item }}</span>
  {%- else -%}
    <a class="nav-link" aria-current="page" href="{{ path(app.current_route, {state: item.value ?? null}) }}">{{ _item }}</a>
  {%- endif -%}
{% endmacro %}

{% block body %}
  <h3 class="mb-3">OrderBundle</h3>

  <p>
    <a href="{{ path('app_order_new') }}" class="btn btn-primary">{{ 'generic.add'|trans }}</a>
  </p>

  <ul class="nav nav-tabs">
    <li class="nav-item">
      {{ _self.nav_link('generic.all', countForState|reduce((carry, item) => carry + item), dto.state == null) }}
    </li>
    {% for case in enum_cases('Siganushka\\OrderBundle\\Enum\\OrderState') %}
      <li class="nav-item">
        {{ _self.nav_link(case, countForState[case.value] ?? 0, dto.state == case) }}
      </li>
    {% endfor %}
  </ul>

  {% embed 'table.html.twig' %}
    {% block th %}
      <th class="text-nowrap">{{ 'order.items'|trans }}</th>
      <th class="text-nowrap">{{ knp_pagination_sortable(pagination, 'order.items_total'|trans, 'o.itemsTotal') }}</th>
      <th class="text-nowrap">{{ knp_pagination_sortable(pagination, 'order.adjustments_total'|trans, 'o.adjustmentsTotal') }}</th>
      <th class="text-nowrap">{{ knp_pagination_sortable(pagination, 'order.total'|trans, 'o.total') }}</th>
      <th class="text-nowrap">{{ 'order.state'|trans }}</th>
      <th class="text-nowrap">{{ knp_pagination_sortable(pagination, 'generic.created_at'|trans, 'o.createdAt') }}</th>
      <th class="text-nowrap">{{ 'generic.action'|trans }}</th>
    {% endblock %}

    {% block td %}
        <td class="fs-sm" colspan="999" style="border-bottom-width: 0">
          <span class="text-secondary">{{ 'order.number'|trans }}</span>
          <code class="user-select-all">{{ _item.number }}</code>
        </td>
      </tr>
      <tr>
        <td class="text-nowrap">
          {% set _collapse_class = 'collapse-' ~ _item.number %}
          <div class="d-flex flex-column row-gap-2">
            {% for item in _item.items %}
              <div class="{{ loop.first is same as(false) ? 'collapse ' ~ _collapse_class }}">
                {% include 'order/_items_entry.twig' with {item} only %}
              </div>
            {% endfor %}
          </div>

          {% set _items_count = _item.items|length %}
          {% if _items_count > 1 %}
            <a role="button" data-bs-toggle="collapse" data-bs-target=".{{ _collapse_class }}" aria-expanded="false" aria-controls="{{ _collapse_class }}" class="fs-sm lh-1 text-decoration-none" style="margin-left: 58px">
              {{ _items_count }} 个项目
              <i class="bi bi-chevron-down"></i>
            </a>
          {% endif %}
        </td>
        <td class="text-nowrap">{{ _item.itemsTotal|intl_currency }}</td>
        <td class="text-nowrap">{{ _item.adjustmentsTotal|intl_currency }}</td>
        <td class="text-nowrap">{{ _item.total|intl_currency }}</td>
        <td class="text-nowrap">
          <span class="badge text-bg-{{ _item.state.theme }}">{{ _item.state|trans }}</span>
        </td>
        <td class="text-nowrap">{{ _item.createdAt|intl_date }}</td>
        <td class="text-nowrap">
          <div class="d-inline-block">
            <a class="dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false">流转</a>
            <ul class="dropdown-menu dropdown-menu-end">
              {% set _transitions = workflow_transitions(_item) %}
              {% for transition in _transitions %}
                {% if transition.name == 'reset' and _transitions|length > 1 %}
                  <li><hr class="dropdown-divider"></li>
                {% endif %}
                <li><a href="{{ path('app_order_workflow', {number: _item.number, transition: transition.name}) }}" class="dropdown-item{{ transition.name == 'reset' ? ' text-danger' }}">{{ transition.name }}</a></li>
              {% else %}
                <li><span class="dropdown-item disabled">No actions available.</span></li>
              {% endfor %}
            </ul>
          </div>
          <a href="{{ path('app_order_show', {_id: _item.number}) }}">{{ 'generic.detail'|trans }}</a>
          <a href="{{ path('app_order_edit', {_id: _item.number}) }}">{{ 'generic.edit'|trans }}</a>
          <a href="{{ path('app_order_delete', {_id: _item.number, _token: csrf_token('delete' ~ _item.number)}) }}" onclick="return confirm('{{ 'generic.delete_confirmation'|trans }}')">{{ 'generic.delete'|trans }}</a>
        </td>
    {% endblock %}
  {% endembed %}
{% endblock %}
